import streamlit as st
import google.generativeai as genai
from PIL import Image

# --- CONFIGURATION ---
st.set_page_config(page_title="AI E-com Copywriter", layout="centered")
st.title("🛍️ AI Product Description Generator")
st.write("Upload a photo and get a high-converting description instantly.")

# Enter your API Key here or set it in Streamlit Secrets
api_key = st.text_input("Enter your Gemini API Key to start:", type="password")

if api_key:
    genai.configure(api_key=api_key)
    model = genai.GenerativeModel('gemini-1.5-flash')

    uploaded_file = st.file_uploader("Choose a product image...", type=["jpg", "jpeg", "png"])

    if uploaded_file is not None:
        image = Image.open(uploaded_file)
        st.image(image, caption='Uploaded Image.', use_column_width=True)
        
        button = st.button("Generate Description")

        if button:
            with st.spinner('Analyzing image and writing copy...'):
                # The "Secret Sauce" Prompt
                prompt = """
                You are a professional E-commerce copywriter. 
                Look at this image and write:
                1. An attention-grabbing Product Title.
                2. A 3-sentence persuasive description.
                3. 5 Bullet points highlighting features/materials.
                4. 3 SEO Keywords.
                Tone: Professional and persuasive.
                """
                
                response = model.generate_content([prompt, image])
                
                st.subheader("Your AI-Generated Description:")
                st.write(response.text)
                st.success("Done! Copy and paste this to your store.")
                
                # Monetization Link
                st.markdown("---")
                st.write("✨ **Want 100+ bulk descriptions?** [Upgrade to Pro here](YOUR_GUMROAD_LINK)")
else:
    st.info("Please enter your API key to use the tool. You can get one for free at Google AI Studio.")
